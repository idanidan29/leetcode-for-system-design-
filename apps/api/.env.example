# Postgres
# Local docker-compose: postgresql+asyncpg://sdip:sdip@localhost:5432/sdip
# Supabase: postgresql+asyncpg://postgres:YOUR_PASSWORD@db.<project-ref>.supabase.co:5432/postgres?ssl=require
DATABASE_URL=postgresql+asyncpg://sdip:sdip@localhost:5432/sdip

# JWT
JWT_SECRET=replace-me-with-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# LLM — get a free Groq key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Rate limit
EVALUATION_RATE_LIMIT_PER_HOUR=5

# CORS (comma-separated; parsed by pydantic-settings)
CORS_ORIGINS=["http://localhost:3000"]
